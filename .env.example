# Backend API base URL (must end with /api/)
API_BASE_URL=http://localhost:8000/api/

# Canonical site URL used for SEO, meta tags, and sitemap
NUXT_PUBLIC_SITE_URL=https://www.frontendjobs.app
NUXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Plausible analytics
NUXT_PUBLIC_PLAUSIBLE_ENABLED=false
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=frontendjobs.app
NUXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/pa-Nokph7gMwhI7ttkvFPYy1.js

# Google AdSense stays disabled until consent/CMP requirements are ready
NUXT_PUBLIC_ADSENSE_ENABLED=false
NUXT_PUBLIC_ADSENSE_CLIENT=ca-pub-8184561234048018

# Stripe — set STRIPE_ENABLED=true in the backend when ready to charge
# No frontend env vars needed (Stripe Checkout is a redirect, not embedded)
