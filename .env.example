# Backend API base URL (must end with /api/)
API_BASE_URL=http://localhost:8000/api/

# Canonical site URL used for SEO, meta tags, and sitemap
NUXT_PUBLIC_SITE_URL=https://www.frontendjobs.app

# Stripe — set STRIPE_ENABLED=true in the backend when ready to charge
# No frontend env vars needed (Stripe Checkout is a redirect, not embedded)

# Firebase — create a project at https://console.firebase.google.com
FIREBASE_API_KEY=your-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
